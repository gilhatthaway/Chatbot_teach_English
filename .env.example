# Copy to .env and fill values
# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=aichat2

# SMTP (used to send admin notifications and OTPs)
SMTP_EMAIL=youremail@example.com
SMTP_PASS=your-email-password-or-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
SMTP_RETRY_COUNT=3

# Admin notifications
ADMIN_NOTIFICATION_EMAIL=admin@example.com
ADMIN_NOTIFICATION_WEBHOOK=

# WebRTC ICE servers JSON (STUN/TURN). Example:
# [
#   {"urls": ["stun:stun.l.google.com:19302"]}
# ]
# Or with TURN credentials:
# [
#   {
#     "urls": ["turn:turn.example.com:3478"],
#     "username": "turnuser",
#     "credential": "turnpassword"
#   }
# ]
WEBRTC_ICE_SERVERS=

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
