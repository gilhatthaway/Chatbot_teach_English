# Environment Configuration Template
# Copy file này thành .env hoặc cập nhật config.js

# Backend URL - QUAN TRỌNG: Thay đổi IP này!
# Tìm IP bằng: ipconfig (Windows) / ifconfig (Mac/Linux)
REACT_APP_BASE_URL=http://172.31.99.114:5000

# API Settings
REACT_APP_API_TIMEOUT=10000

# Debug Mode
REACT_APP_DEBUG=true

# Default Settings
REACT_APP_DEFAULT_HISTORY_LIMIT=5
REACT_APP_DEFAULT_MODEL=gemini-2.5-flash

# Test Credentials (nếu muốn auto-test)
REACT_APP_TEST_EMAIL=admin@gmail.com
REACT_APP_TEST_PASSWORD=bao123
